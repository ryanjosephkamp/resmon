{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist/electron",
    "rootDir": "./electron",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0"
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
