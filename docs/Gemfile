source "https://rubygems.org"

# GitHub Pages builds this site automatically; the gem below pins the
# Jekyll + plugin versions to whatever GitHub Pages currently supports.
# This Gemfile is only needed for local previews via ``bundle exec jekyll serve``.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end
